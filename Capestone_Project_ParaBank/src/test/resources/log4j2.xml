<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="OFF">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss} %-5level %c{1} - %msg%n"/>
        </Console>
        <File name="FileLogger" fileName="logs/automation.log" append="true">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level %c{1} - %msg%n"/>
        </File>
    </Appenders>
    <Loggers>
        <Logger name="org.testng" level="error" additivity="false">
            <AppenderRef ref="FileLogger"/>
        </Logger>
        <Logger name="io.github.bonigarcia" level="error" additivity="false">
            <AppenderRef ref="FileLogger"/>
        </Logger>
        <Logger name="org.openqa.selenium" level="error" additivity="false">
            <AppenderRef ref="FileLogger"/>
        </Logger>
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="FileLogger"/>
        </Root>
    </Loggers>
</Configuration>
